{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude.skills/literature-library-eval/run-config-v1",
  "title": "Run Configuration for Literature Library Evaluation",
  "description": "Single source of truth for every evaluation run. Generated by AI during intake; consumed by all downstream scripts.",
  "type": "object",
  "required": ["schema_version", "project", "library", "automation", "output"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "project": {
      "type": "object",
      "required": ["research_question", "review_type", "scope_status"],
      "properties": {
        "research_question": {"type": "string", "minLength": 1},
        "review_type": {"type": "string", "enum": ["叙事综述", "系统综述", "范围综述", "快速综述", "伞式综述"]},
        "engineering_profile": {"type": "array", "items": {"type": "string"}},
        "scope_status": {"type": "string", "enum": ["in_scope", "cross_domain", "out_of_scope", "scope_uncertain"]},
        "scope_rationale": {"type": "string"},
        "time_range": {
          "type": "object",
          "properties": {
            "start": {"type": ["integer", "null"]},
            "end": {"type": ["integer", "null"]}
          }
        },
        "languages": {"type": "array", "items": {"type": "string"}, "default": ["en"]},
        "allowed_assessment_level": {"type": "string", "enum": ["full", "limited_metadata_only", "stop"]}
      }
    },
    "library": {
      "type": "object",
      "required": ["provided"],
      "properties": {
        "provided": {"type": "boolean"},
        "path": {"type": ["string", "null"]},
        "format": {"type": ["string", "null"], "enum": ["zotero_mcp", "zotero_api", "bibtex", "csv", "json", "ris", "pdf_directory", null]},
        "record_count": {"type": ["integer", "null"]},
        "normalization_required": {"type": "boolean", "default": true}
      }
    },
    "automation": {
      "type": "object",
      "required": ["allow_search"],
      "properties": {
        "allow_search": {"type": "boolean"},
        "allow_query_refinement": {"type": "boolean", "default": false},
        "allowed_sources": {"type": "array", "items": {"type": "string"}},
        "stop_conditions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence_inputs": {
      "type": "object",
      "properties": {
        "benchmark": {"type": ["string", "null"], "description": "A1 baseline file path"},
        "gold": {"type": ["string", "null"], "description": "A2 gold set file path"},
        "query_log": {"type": ["string", "null"], "description": "Run-log for F1/A2"},
        "source_snapshot": {"type": ["string", "null"], "description": "Collector snapshot for A3"},
        "screening_decisions": {"type": ["string", "null"], "description": "Screening decisions for B"},
        "deduplication_log": {"type": ["string", "null"], "description": "Dedup/version log for F4"},
        "failed_sources": {"type": "array", "items": {"type": "string"}}
      }
    },
    "standards": {
      "type": "object",
      "properties": {
        "defaults_profile": {"type": "string", "description": "Which profile generated the defaults"},
        "user_overrides": {"type": "object", "description": "User-provided threshold overrides"},
        "confirmed_by_user": {"type": "boolean", "default": false}
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "language": {"type": "string", "default": "zh-CN"},
        "formats": {"type": "array", "items": {"type": "string"}, "default": ["md", "html", "json"]},
        "include_standards_appendix": {"type": "boolean", "default": true}
      }
    },
    "generated_by": {"type": "string", "description": "Agent name or session ID"},
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
